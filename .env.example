# =============================================================
# activia-trace — Root Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=activia
POSTGRES_PASSWORD=activia_secret
POSTGRES_DB=activia_trace

# --- Backend env vars (see backend/.env.example for all options) ---
# These are read by docker-compose and override backend/.env defaults.
# For local development, set them in backend/.env directly.
DATABASE_URL=postgresql+asyncpg://activia:activia_secret@localhost:5432/activia_trace
SECRET_KEY=change-me-32-chars-minimum-secret-key-here
ENCRYPTION_KEY=change-me-exactly-32-characters!
APP_ENV=development
LOG_LEVEL=INFO
OTEL_ENABLED=false

# --- Frontend env vars (see frontend/.env.example for all options) ---
# VITE_API_BASE_URL is set in frontend/.env
