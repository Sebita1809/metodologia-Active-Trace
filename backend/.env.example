# =============================================================
# activia-trace -- Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://trace_user:trace_pass@localhost:5432/trace_db

# --- Security ---
SECRET_KEY=change-me-32-chars-minimum-secret-key-here
ENCRYPTION_KEY=change-me-exactly-32-characters!
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Test database ---
TEST_DATABASE_URL=postgresql+asyncpg://trace_user:trace_pass@localhost:5432/trace_test_db

# --- Observability ---
OTEL_ENABLED=false

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
